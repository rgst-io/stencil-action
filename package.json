{
  "name": "stencil-action",
  "description": "GitHub Actions for interacting with stencil",
  "version": "v3.0.0",
  "author": "Jared Allard <jaredallard@users.noreply.github.com>",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/jaredallard/stencil-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaredallard/stencil-action.git"
  },
  "bugs": {
    "url": "https://github.com/jaredallard/stencil-action/issues"
  },
  "keywords": [
    "actions",
    "stencil"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "yarn run format:write && yarn run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "package": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "yarn run package -- --watch",
    "test": "yarn run ci-test",
    "ci-test-local": "gh act --platform ubuntu-latest=ghcr.io/catthehacker/ubuntu:full-24.04 --job test-action --secret GITHUB_TOKEN=$(gh auth token)",
    "all": "yarn run format:write && yarn run lint && yarn run test && yarn run coverage && yarn run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/io": "^3.0.2",
    "gitea-js": "^1.23.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.5",
    "prettier-eslint": "^17.1.1",
    "rollup": "^4.62.2",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae"
}
